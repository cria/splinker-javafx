<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<Pane id="pane" fx:id="pane" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="350.0" prefWidth="480.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="br.org.cria.splinkerapp.controllers.FileSelectionController">
   <children>
      <Label layoutX="14.0" layoutY="24.0" prefHeight="25.0" prefWidth="242.0" text="Origem do arquivo">
         <font>
            <Font size="18.0" />
         </font>
      </Label>
      <RadioButton fx:id="localOption" layoutX="14.0" layoutY="73.0" mnemonicParsing="false" onAction="#onSourceTypeChanged" selected="true" text="Arquivo local" />
      <RadioButton fx:id="remoteOption" layoutX="140.0" layoutY="73.0" mnemonicParsing="false" onAction="#onSourceTypeChanged" text="Google Drive" />
      <HBox fx:id="localBox" layoutX="14.0" layoutY="136.0" prefHeight="35.0" prefWidth="464.0" spacing="3.0">
         <children>
            <TextField fx:id="localFilePath" editable="false" prefHeight="35.0" prefWidth="409.0" />
            <Button id="btnSelectFile" fx:id="btnSelectFile" mnemonicParsing="false" onMouseClicked="#onButtonSelectFileClicked" prefHeight="35.0" prefWidth="52.0" />
         </children>
      </HBox>
      <HBox fx:id="remoteBox" layoutX="14.0" layoutY="136.0" managed="false" prefHeight="35.0" prefWidth="464.0" spacing="3.0" visible="false">
         <children>
            <TextField fx:id="remoteUrl" prefHeight="35.0" prefWidth="461.0" promptText="Cole aqui o link do Google Drive ou Google Sheets" />
         </children>
      </HBox>
      <Label layoutX="14.0" layoutY="182.0" prefHeight="66.0" prefWidth="431.0" text="Para arquivos do Google Drive ou Google Sheets, compartilhe o arquivo com permissão de leitura para qualquer pessoa com o link." wrapText="true" />
      <Button id="btnSave" fx:id="btnSave" layoutX="194.0" layoutY="252.0" mnemonicParsing="false" onMouseClicked="#onButtonSaveClicked" prefHeight="36.0" prefWidth="77.0" styleClass="success-button" text="Salvar" />
   </children>
</Pane>
